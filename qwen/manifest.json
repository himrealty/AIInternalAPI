{
  "manifest_version": 3,
  "name": "Qwen API Controller",
  "version": "1.0",
  "description": "Send commands to Qwen Chat from outside",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["https://chat.qwen.ai/*", "https://qwenlm.github.io/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.qwen.ai/*", "https://qwenlm.github.io/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Qwen API"
  }
}