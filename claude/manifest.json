{
  "manifest_version": 3,
  "name": "Claude Sidebar",
  "version": "1.0",
  "description": "Chat with Claude alongside claude.ai",
  "permissions": ["scripting", "activeTab", "tabs"],
  "host_permissions": ["https://claude.ai/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}